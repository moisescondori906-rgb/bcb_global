# BCB GLOBAL - CONFIGURACIÓN DE ENTORNO (v7.0.6)

# 1. SERVIDOR & SEGURIDAD
PORT=4000
JWT_SECRET=tu_secreto_super_seguro_aqui
NODE_ENV=production
BACKEND_URL=https://api.bcb-global.com

# 2. BASE DE DATOS (MYSQL)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=tu_password_aqui
MYSQL_DATABASE=bcb_global

# 3. CACHÉ & COLAS (REDIS)
REDIS_URL=redis://localhost:6379

# 4. TELEGRAM (MULTI-BOT)
# Obtén los tokens en @BotFather
TELEGRAM_BOT_TOKEN_ADMIN=tu_token_aqui
TELEGRAM_CHAT_ADMIN=tu_chat_id_aqui

# Opcionales (Fallback automático a ADMIN si no se configuran)
TELEGRAM_BOT_TOKEN_RETIROS=tu_token_aqui
TELEGRAM_CHAT_RETIROS=tu_chat_id_aqui

TELEGRAM_BOT_TOKEN_SECRETARIA=tu_token_aqui
TELEGRAM_CHAT_SECRETARIA=tu_chat_id_aqui

# 5. ALMACENAMIENTO (CLOUDINARY)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# 6. CONFIGURACIÓN DE NEGOCIO
DEFAULT_INVITE_CODE=BCB2026
MIN_WITHDRAWAL=25
MAX_DAILY_TASKS_FREE=2
