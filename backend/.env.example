# BCB GLOBAL - CONFIGURACIÓN DE ENTORNO (v9.0.0 - RESILIENT EDITION)

# 1. SERVIDOR & SEGURIDAD (Obligatorio)
PORT=4000
JWT_SECRET=tu_secreto_super_seguro_aqui
NODE_ENV=production
# URL pública para webhooks y callbacks
BACKEND_URL=https://bcb-global.com/api

# 2. BASE DE DATOS (MYSQL - Obligatorio)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=tu_password_aqui
MYSQL_DATABASE=bcb_global

# 3. CACHÉ & COLAS (REDIS - Obligatorio)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# 4. TELEGRAM (MULTI-BOT - Obligatorio)
# Obtén los tokens en @BotFather
TELEGRAM_BOT_TOKEN_ADMIN=tu_token_aqui
TELEGRAM_CHAT_ADMIN=tu_chat_id_aqui

# Bots especializados (Fallback automático a ADMIN si no se configuran)
TELEGRAM_BOT_TOKEN_RETIROS=tu_token_aqui
TELEGRAM_CHAT_RETIROS=tu_chat_id_aqui

TELEGRAM_BOT_TOKEN_SECRETARIA=tu_token_aqui
TELEGRAM_CHAT_SECRETARIA=tu_chat_id_aqui

# 5. ALMACENAMIENTO (CLOUDINARY - Obligatorio para vouchers)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# 6. CONFIGURACIÓN DE LOGS
LOG_LEVEL=info # debug, info, warn, error
